enum Role {
  COMPANY
  CANDIDATE
  ADMIN
}

model User {
  id String @id @default(uuid())

  email    String @unique
  password String
  role     Role

  companyProfile   CompanyProfile?
  candidateProfile CandidateProfile?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("users")
}
