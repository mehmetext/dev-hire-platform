enum WorkType {
  REMOTE
  HYBRID
  ONSITE
}

enum JobStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

model Job {
  id String @id @default(uuid())

  companyProfileId String
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id])

  title            String           @map("title")
  description      String           @map("description")
  requirements     String[]         @map("requirements")
  requirementsText String?          @map("requirements_text")
  location         String           @map("location")
  workType         WorkType         @map("work_type")
  status           JobStatus        @map("status")
  expiresAt        DateTime?        @map("expires_at")
  jobApplications  JobApplication[]
  jobQuestions     JobQuestion[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("jobs")
}

enum JobApplicationStatus {
  PENDING
  REVIEWED
  INTERVIEWED
  OFFER_MADE
  HIRED
  REJECTED
}

model JobApplication {
  id    String @id @default(uuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id])
  candidateCVId      String
  candidateCV        CandidateCV      @relation(fields: [candidateCVId], references: [id])

  status             JobApplicationStatus @default(PENDING) @map("status")
  jobQuestionAnswers JobQuestionAnswers[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([jobId, candidateProfileId])
  @@map("job_applications")
}

enum QuestionType {
  TEXT
  TEXTAREA
  NUMBER
  BOOLEAN
}

model JobQuestion {
  id    String @id @default(uuid())
  jobId String @map("job_id")
  job   Job    @relation(fields: [jobId], references: [id])

  question           String
  questionType       QuestionType
  isRequired         Boolean              @default(true) @map("is_required")
  sortOrder          Int                  @default(0) @map("sort_order")
  jobQuestionAnswers JobQuestionAnswers[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("job_questions")
}

model JobQuestionAnswers {
  id            String      @id @default(uuid())
  jobQuestionId String
  jobQuestion   JobQuestion @relation(fields: [jobQuestionId], references: [id])

  jobApplicationId String
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id])

  answer String

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([jobQuestionId, jobApplicationId])
  @@map("job_question_answers")
}
