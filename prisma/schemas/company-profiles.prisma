enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

model CompanyProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  name             String           @map("name")
  logoUrl          String?          @map("logo_url")
  subscriptionPlan SubscriptionPlan @map("subscription_plan")
  webhooks         CompanyWebhook[]
  jobs             Job[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("company_profiles")
}

model CompanyWebhook {
  id               String         @id @default(uuid())
  companyProfileId String
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id])

  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([companyProfileId, webhookId])
  @@map("company_webhooks")
}
